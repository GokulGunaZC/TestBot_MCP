# =============================================================================
# Runtime configuration for the Healix Webapp Docker image.
#
# 1. Copy this file:   cp .env.docker.example .env.docker
# 2. Fill in real values.
# 3. Pass to docker:   docker run --env-file .env.docker ...
#                  or  docker compose up   (compose reads .env.docker by default
#                                          when env_file is set in compose.yml)
#
# Notes:
#   • NEXT_PUBLIC_* vars are NOT listed here — they are baked into the image
#     at build time and cannot be overridden at runtime.
#   • Never commit a filled-in copy of this file. .env.docker is gitignored.
# =============================================================================

# ── Database (REQUIRED) ─────────────────────────────────────────────────────
# Supabase Transaction Pooler URL (port 6543) recommended for production.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Supabase service role (REQUIRED) ────────────────────────────────────────
# Server-side only. Found in: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OpenAI (REQUIRED) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# ── Stripe (REQUIRED if billing is enabled) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_TEAM=price_...

# ── Inngest (OPTIONAL — only when HEALIX_GEN_ASYNC=true) ───────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=
HEALIX_GEN_ASYNC=false

# ── Feature flags / tuning (OPTIONAL) ───────────────────────────────────────
HEALIX_PLANNER_AGENT=0
AI_MAX_REQUESTS_PER_MINUTE=20

# ── Email (OPTIONAL — Resend) ───────────────────────────────────────────────
RESEND_API_KEY=

# ── Migrations (OPTIONAL) ───────────────────────────────────────────────────
# Set to "true" to apply pending Drizzle migrations on every container start.
# Recommended: leave "false" and run migrations once via:
#   docker run --rm --env-file .env.docker healix-webapp:<tag> \
#     node /app/webapp/docker/migrate.mjs
RUN_MIGRATIONS=false

# ── Port (OPTIONAL — defaults to 3000) ─────────────────────────────────────
PORT=3000
