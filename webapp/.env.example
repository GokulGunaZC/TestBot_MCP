# ============================================================
# Webapp Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key for server-side operations (artifact uploads, admin tasks)
# Found in: Supabase Dashboard → Settings → API → service_role key
# WARNING: Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Database (Drizzle / direct connection) ───────────────────
# For LOCAL development: use the direct connection string (port 5432)
#   Found in: Supabase Dashboard → Settings → Database → Connection string → URI
# For PRODUCTION (Vercel): use the Transaction pooler URL (port 6543)
#   Found in: Supabase Dashboard → Settings → Database → Connection pooling → Transaction mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── OpenAI (SERVER-SIDE ONLY) ────────────────────────────────
# This key is used by /api/generate-tests and /api/analyze-failures
# to handle AI requests on behalf of all MCP users.
# Users never need their own OpenAI key — they authenticate via HEALIX_API_KEY.
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
