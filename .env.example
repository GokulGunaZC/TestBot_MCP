# ============================================================
# Healix — Root .env.example
# Single source of truth for every env var used across webapp + MCP.
# Copy to .env.local (root) and into webapp/.env.local, then fill values.
# ============================================================

# ── Supabase (webapp) ────────────────────────────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role key — used server-side only (artifact uploads, admin).
# WARNING: never expose in client code. Never commit.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Database (Drizzle) ───────────────────────────────────────
# Local dev:   direct connection (port 5432)
# Production:  Transaction pooler URI (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── OpenAI (webapp, server-side only) ────────────────────────
# Used by /api/generate-tests, /api/parse-prd, /api/analyze-failures.
# Never touches user machines — MCP clients authenticate via HEALIX_API_KEY.
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.5-mini

# ── Webapp dashboard URL (optional) ──────────────────────────
# Where the MCP deep-links into when a test run finishes. Defaults to the
# production Vercel URL committed in @healix/mcp. Override for local dev.
HEALIX_DASHBOARD_URL=https://app.healix.sh

# ── MCP (users' machines) ────────────────────────────────────────────
# Users only ever need this one — everything else lives on the webapp.
# browser-use LLM calls are automatically proxied through /api/llm-proxy
# using this key, so no local OPENAI_API_KEY is required on user machines.
HEALIX_API_KEY=hlx_...

# ── Feature flags (optional) ─────────────────────────────────
# Opt-in LLM-driven agent planner. Default (off) uses rule-based routing.
HEALIX_PLANNER_AGENT=0
# AI-guard requests-per-minute ceiling per user.
AI_MAX_REQUESTS_PER_MINUTE=20
